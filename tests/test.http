@baseUrl = http://127.0.0.1:8000
@json = application/json

### Health check
GET {{baseUrl}}/

### Species - list
GET {{baseUrl}}/species/

### Species - create
POST {{baseUrl}}/species/
Content-Type: {{json}}

{
  "name": "Common Swift",
  "scientific_name": "Apus apus",
  "family": "Apodidae",
  "conservation_status": "Least Concern",
  "wingspan_cm": 42.5
}

### Species - filter by conservation status
GET {{baseUrl}}/species/?conservation_status=Least Concern

### Species - get one
GET {{baseUrl}}/species/1

### Species - get with birds (back-reference)
GET {{baseUrl}}/species/1/with-birds

### Species - update
PUT {{baseUrl}}/species/1
Content-Type: {{json}}

{
  "name": "Common Swift Updated",
  "wingspan_cm": 43.0
}

### Birds - list
GET {{baseUrl}}/birds/

### Birds - list with pagination
GET {{baseUrl}}/birds/?skip=0&limit=1

### Birds - filter by species
GET {{baseUrl}}/birds/?species_id=1

### Birds - create
POST {{baseUrl}}/birds/
Content-Type: {{json}}

{
  "nickname": "Skye",
  "ring_code": "SWIFT-001",
  "age": 2,
  "species_id": 1
}

### Birds - create with negative age (should fail)
POST {{baseUrl}}/birds/
Content-Type: {{json}}

{
  "nickname": "Invalid",
  "ring_code": "INVALID-001",
  "age": -1,
  "species_id": 1
}

### Birds - get one
GET {{baseUrl}}/birds/1

### Birds - update
PUT {{baseUrl}}/birds/1
Content-Type: {{json}}

{
  "nickname": "Skye Updated",
  "age": 3
}

### Birds - delete
DELETE {{baseUrl}}/birds/1

### Birdspotting - list
GET {{baseUrl}}/birdspotting/

### Birdspotting - filter by observer
GET {{baseUrl}}/birdspotting/?observer_name=Pawel

### Birdspotting - get one
GET {{baseUrl}}/birdspotting/1

### Birdspotting - create
POST {{baseUrl}}/birdspotting/
Content-Type: {{json}}

{
  "bird_id": 1,
  "spotted_at": "2026-03-13T10:00:00",
  "location": "City Park",
  "observer_name": "Pawel",
  "notes": "Testing from test.http"
}

### Birdspotting - update
PUT {{baseUrl}}/birdspotting/1
Content-Type: {{json}}

{
  "location": "City Park Updated",
  "notes": "Updated notes"
}

### Birdspotting - delete
DELETE {{baseUrl}}/birdspotting/1

### Species - delete
DELETE {{baseUrl}}/species/1
